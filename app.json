{
  "expo": {
    "name": "AgentCall",
    "slug": "agentcall-mobile",
    "scheme": "agentcall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "description": "A generic mobile voice client for LiveKit-powered AI agents.",
    "githubUrl": "https://github.com/SnowfallHD/agentcall-mobile",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.kryden.agentcall",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "AgentCall connects to your private Tailnet or LAN token server.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false
    },
    "android": {
      "package": "ai.kryden.agentcall",
      "adaptiveIcon": {
        "backgroundColor": "#08111F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication"
          }
        }
      ],
      "@config-plugins/react-native-webrtc"
    ],
    "extra": {
      "livekitUrl": "",
      "tokenEndpoint": "",
      "defaultRoom": "agentcall-demo",
      "eas": {
        "projectId": "ccc99767-dbef-4f68-9ba1-d9506ecc6cf3"
      }
    }
  }
}

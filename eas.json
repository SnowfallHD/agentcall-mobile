{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "AGENTCALL_ALLOW_INSECURE_LOCAL_HTTP": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "AGENTCALL_ALLOW_INSECURE_LOCAL_HTTP": "1"
      },
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
